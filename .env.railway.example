# Railway — variáveis por serviço
# Docs: https://docs.railway.com/
# Copie/adapte no dashboard Railway (Settings → Variables) ou via CLI

# ========== Serviço: API (backend/) ==========
SECRET_KEY=gerar-string-longa-aleatoria
DEBUG=False
# Railway injeta automaticamente:
# DATABASE_URL=postgresql://...
# REDIS_URL=redis://...
# RAILWAY_PUBLIC_DOMAIN=api-xxx.up.railway.app
# PORT=...

ALLOWED_HOSTS=${RAILWAY_PUBLIC_DOMAIN}
CORS_ALLOWED_ORIGINS=https://frontend-xxx.up.railway.app
CSRF_TRUSTED_ORIGINS=https://frontend-xxx.up.railway.app

USE_SQLITE=False
USE_REDIS=True
GUNICORN_WORKERS=1
CELERY_CONCURRENCY=1

# Fotos: volume Railway em /app/media (padrão) OU Cloudflare R2 (USE_S3)
SERVE_MEDIA=True

# R2/S3 (opcional — substitui volume local; bucket com acesso público ou custom domain)
# USE_S3=True
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=coroinhas
# MINIO_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# MINIO_USE_SSL=True
# AWS_S3_REGION_NAME=auto
# AWS_S3_CUSTOM_DOMAIN=pub-xxx.r2.dev

# Inscrições online — padrão fechado; coordenador abre em Dashboard → Inscrições
# INSCRICOES_ABERTAS=True força abertas (opcional, sobrescreve o painel)
INSCRICOES_ABERTAS=False
NOTIFICACAO_ESCALA_CANAL=WhatsApp

# --- WhatsApp (recomendado Railway: WAHA) ---
WHATSAPP_PROVIDER=waha
WHATSAPP_API_URL=https://waha-xxx.up.railway.app
WHATSAPP_API_TOKEN=mesma-chave-do-WAHA_API_KEY
WHATSAPP_WAHA_SESSION=default
WHATSAPP_DEFAULT_COUNTRY_CODE=55

# Outros provedores: http | evolution | meta — ver waha/.env.railway.example e README

# --- E-mail (SMTP) ---
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=coroinhas@paroquia.org

# ========== Serviço: Worker (backend/, mesmas vars da API exceto PORT) ==========
# Mesmo DATABASE_URL, REDIS_URL, SECRET_KEY (referencie variables compartilhadas)
# Config file: railway.worker.toml (Settings → Config-as-code)

# ========== Serviço: Frontend (frontend/) ==========
# Build-time — obrigatório antes do deploy:
NEXT_PUBLIC_API_URL=https://api-xxx.up.railway.app/api/v1

# ========== Plugins Railway (criar no projeto) ==========
# 1. PostgreSQL → linkar DATABASE_URL na API e Worker
# 2. Redis → linkar REDIS_URL na API e Worker
#    CELERY_BROKER_URL=${REDIS_URL}/1  (opcional, ou use REDIS_URL direto)
