# Desenvolvimento local (sem Docker) — copie para .env:
#   copy .env.local.example .env
#
# Ou no PowerShell:
#   Copy-Item .env.local.example .env

SECRET_KEY=dev-secret-key-local
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite — não precisa de PostgreSQL
USE_SQLITE=True

# Cache em memória — não precisa de Redis
USE_REDIS=False

CORS_ALLOWED_ORIGINS=http://localhost:3000

AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW=3600
INSCRICAO_RATE_LIMIT_ATTEMPTS=10
INSCRICAO_RATE_LIMIT_WINDOW=3600

# Inscrições online — padrão fechado; coordenador abre em Dashboard → Inscrições
# INSCRICOES_ABERTAS=True força abertas (opcional)
INSCRICOES_ABERTAS=False

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
