# Produção — VPS único com Docker Compose
# cp .env.prod.example .env  &&  nano .env

# --- Segurança Django ---
SECRET_KEY=change-me-use-long-random-string-min-50-chars
DEBUG=False
# Domínio público + IP do VPS (para acesso direto durante setup)
ALLOWED_HOSTS=coroinhas.seudominio.com.br,123.45.67.89,localhost,api,nginx

# --- Banco (container db) ---
DB_NAME=coroinhas
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

USE_SQLITE=False
USE_REDIS=True
REDIS_URL=redis://redis:6379/0

# --- CORS (URL pública do site, com https após Cloudflare) ---
CORS_ALLOWED_ORIGINS=https://coroinhas.seudominio.com.br,http://123.45.67.89

# --- URL pública — IMPORTANTE: usada no BUILD do frontend (NEXT_PUBLIC_*) ---
# Deve ser a URL que o browser usa para chamar a API (via nginx /api/v1)
NEXT_PUBLIC_API_URL=https://coroinhas.seudominio.com.br/api/v1

HTTP_PORT=80

# --- Performance VPS pequeno (2 GB RAM) ---
GUNICORN_WORKERS=1
CELERY_CONCURRENCY=1

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Rate limits ---
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW=3600
INSCRICAO_RATE_LIMIT_ATTEMPTS=10
INSCRICAO_RATE_LIMIT_WINDOW=3600

# --- GitLab Registry (deploy --pull; opcional se build local) ---
# CI_REGISTRY_IMAGE=registry.gitlab.com/seu-grupo/gerenciamento-coroinhas
# API_IMAGE=registry.gitlab.com/seu-grupo/gerenciamento-coroinhas/api:latest
# FRONTEND_IMAGE=registry.gitlab.com/seu-grupo/gerenciamento-coroinhas/frontend:latest

# --- E-mail (SMTP) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=coroinhas@paroquia.org

# --- WhatsApp (provedor: http | evolution | meta) ---
# WHATSAPP_PROVIDER=http
# HTTP genérico — POST JSON {to, message}
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=

# Evolution: WHATSAPP_PROVIDER=evolution + URL .../message/sendText/{instancia} + apikey
# Meta: WHATSAPP_PROVIDER=meta + WHATSAPP_API_TOKEN + WHATSAPP_PHONE_NUMBER_ID
# WHATSAPP_GRAPH_VERSION=v21.0
# WHATSAPP_DEFAULT_COUNTRY_CODE=55

# --- Notificação automática ao montar escala ---
NOTIFICACAO_ESCALA_AUTOMATICA=True
NOTIFICACAO_ESCALA_CANAL=WhatsApp

# --- Mídia: volume Docker (padrão). MinIO só se precisar S3 ---
# USE_MINIO=False
