# Railway — serviço WAHA (WhatsApp HTTP API)
# Copie/adapte no dashboard do serviço waha/ (Root Directory: /waha)

WAHA_API_KEY=mesma-chave-usada-em-WHATSAPP_API_TOKEN-na-API
WAHA_BASE_URL=https://waha-xxx.up.railway.app
WAHA_DASHBOARD_USERNAME=coordenador
WAHA_DASHBOARD_PASSWORD=senha-forte-dashboard
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=senha-forte-swagger
WAHA_API_KEY_EXCLUDE_PATH=ping
WHATSAPP_RESTART_ALL_SESSIONS=True
WAHA_AUTO_START_DELAY_SECONDS=5

# Volume Railway: /app/.sessions (sessão WhatsApp persiste entre redeploys)

# ========== API + Worker (mesmas vars nos dois) ==========
WHATSAPP_PROVIDER=waha
WHATSAPP_API_URL=https://waha-xxx.up.railway.app
WHATSAPP_API_TOKEN=mesma-chave-do-WAHA_API_KEY
WHATSAPP_WAHA_SESSION=default
WHATSAPP_DEFAULT_COUNTRY_CODE=55
NOTIFICACAO_ESCALA_CANAL=WhatsApp
